# ── Supabase ─────────────────────────────────────────────────────────────────
# Server-side (Express) — also used as VITE_ prefix for client Vite build
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Client-side (Vite) — must match SUPABASE_URL / SUPABASE_ANON_KEY above
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ── SMS / OTP ─────────────────────────────────────────────────────────────────
AUTHENTICA_API_KEY=your-authentica-api-key
# Set to "true" in local dev to skip Authentica and accept any 4-digit OTP
# OTP_BYPASS=true

# ── Admin seed ────────────────────────────────────────────────────────────────
# On startup the server upserts an admin with these credentials.
# Leave unset if you manage admins directly in the database.
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=change-me

# ── Server ────────────────────────────────────────────────────────────────────
# Restrict CORS to this origin in production. Unset = allow all (dev default).
# FRONTEND_URL=https://emaraa.app
# PORT=5000
# HOST=127.0.0.1   # local dev only — leave unset in production (defaults to 0.0.0.0)
