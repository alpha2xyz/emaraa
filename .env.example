# Server-side env vars (used by Express — loaded via --env-file=.env in dev, Vercel dashboard in prod)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
AUTHENTICA_API_KEY=your-authentica-api-key

# Client-side env vars (loaded by Vite — .env.local in dev, Vercel dashboard in prod)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Sentry error monitoring — leave EMPTY to keep Sentry fully disabled (no-op).
# Set these only when you want error tracking turned on.
SENTRY_DSN=
VITE_SENTRY_DSN=

# Test login (local + preview ONLY — never set in Production)
# Whitelisted fake numbers log in with OTP_TEST_CODE, skip SMS, and suppress all outbound SMS.
OTP_TEST_MODE=
OTP_TEST_NUMBERS=
OTP_TEST_CODE=

# Zoho Mail SMTP — admin report emails
ZOHO_SMTP_USER=
ZOHO_SMTP_PASS=
ADMIN_REPORT_TO=info@emaraa.app
CRON_SECRET=
